@page "/Recipients/View"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using No_Kill_Inventory.Data
@inject ApplicationDbContext Context

@attribute [Authorize]

<style>
    table {
        border-collapse: collapse;
        width: 100%;
    }
    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }
    tr:nth-child(even) {
        background-color: #f9f9f9;
    }
    tr:hover {
        background-color: #f1f1f1;
        cursor: pointer;
    }
    .expanded-row {
        background-color: #f4f4f4;
    }
    .details {
        padding: 10px;
        border-top: 1px solid #ddd;
    }
    .search-bar {
        margin-bottom: 20px;
        width: 300px;
    }
</style>

<PageTitle>Recipients</PageTitle>

<h1>Recipients</h1>

<div>
    <input type="text" @bind="SearchTerm" class="search-bar" placeholder="Search by name..." />
</div>

<table>
    <thead>
    <tr>
        <th>Name</th>
        <th>Phone</th>
        <th>Email</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var recipient in FilteredRecipients)
    {
        <tr @onclick="() => ToggleRecipientDetails(recipient)">
            <td>@recipient.FirstName @recipient.LastName</td>
            <td>@recipient.PhoneNumber</td>
            <td>@recipient.Email</td>
        </tr>
        @if (ExpandedRecipient == recipient)
        {
            <tr class="expanded-row">
                <td colspan="3">
                    <div class="details">
                        <h4>Pets</h4>
                        <ul>
                            @if (recipient.Pets != null)
                            {
                                foreach (var pet in recipient.Pets)
                                {
                                    <li>@pet.Type: @pet.Name</li>
                                }
                            }
                            else
                            {
                                <li>No pets listed.</li>
                            }
                        </ul>
                    </div>
                </td>
            </tr>
        }
    }
    </tbody>
</table>

@code {
    private List<Recipient> Recipients { get; set; } = new();
    private string SearchTerm { get; set; } = string.Empty;
    private Recipient? ExpandedRecipient { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Recipients = await Context.Recipients
            .Include(r => r.Pets) // Only include this if Recipient has a Pets nav property
            .ToListAsync();
    }

    private List<Recipient> FilteredRecipients => Recipients
        .Where(r => string.IsNullOrWhiteSpace(SearchTerm)
                    || $"{r.FirstName} {r.LastName}".Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList();

    private void ToggleRecipientDetails(Recipient recipient)
    {
        if (ExpandedRecipient == recipient)
        {
            ExpandedRecipient = null;
        }
        else
        {
            ExpandedRecipient = recipient;
        }
    }
}
